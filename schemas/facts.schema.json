{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "syncskl://schemas/facts.schema.json",
  "title": "syncskl facts file",
  "type": "object",
  "additionalProperties": false,
  "required": ["facts"],
  "properties": {
    "facts": {
      "type": "object",
      "patternProperties": {
        "^[a-zA-Z0-9_.-]+$": {
          "type": "object",
          "additionalProperties": false,
          "required": ["value", "meta"],
          "properties": {
            "value": {},
            "meta": {
              "type": "object",
              "additionalProperties": false,
              "required": ["source", "confidence", "updated_at"],
              "properties": {
                "source": { "type": "string", "minLength": 1 },
                "confidence": {
                  "type": "string",
                  "enum": ["confirmed", "likely", "tentative"]
                },
                "updated_at": {
                  "type": "string",
                  "minLength": 8
                },
                "expires_at": { "type": "string" },
                "tags": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            }
          }
        }
      },
      "additionalProperties": false
    }
  }
}
